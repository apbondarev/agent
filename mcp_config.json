{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "yandexSearch": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://d5de9siimt9bkld7viic.emzafcgx.apigw.yandexcloud.net:3000/sse",
        "--header",
        "ApiKey: ${YANDEX_API_KEY}",
        "--header",
        "FolderId: ${YANDEX_FOLDER_ID}"
      ]
    },
    "fetch": {
        "command": "uvx",
        "args": [
            "mcp-server-fetch"
        ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "git": {
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "."
      ]
    },
    "shell": {
      "command": "npx",
      "args": [
        "-y",
        "@artinet/bash-mcp"
      ]
    }
  }
}